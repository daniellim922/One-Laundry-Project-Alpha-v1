{
    "name": "One Laundry",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "db:local:start": "npx supabase start",
        "db:local:status": "npx supabase status",
        "db:local:stop": "npx supabase stop",
        "db:studio": "npx drizzle-kit studio",
        "db:seed": "npx drizzle-kit push && npx tsx db/seed/seed.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:wipe": "npx tsx db/wipe-db.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:worker": "vitest run app/dashboard/worker services/worker app/api/workers",
        "test:e2e": "playwright test",
        "test:e2e:worker": "playwright test test/e2e/worker*.spec.ts --project=chromium",
        "test:e2e:ui": "playwright test --ui"
    },
    "dependencies": {
        "@headlessui/react": "^2.2.9",
        "@hookform/resolvers": "^5.2.2",
        "@tanstack/react-table": "^8.21.3",
        "archiver": "^7.0.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.45.1",
        "lucide-react": "^0.575.0",
        "next": "16.1.6",
        "next-themes": "^0.4.6",
        "pg": "^8.18.0",
        "radix-ui": "^1.4.3",
        "react": "19.2.3",
        "react-day-picker": "^9.14.0",
        "react-dom": "19.2.3",
        "react-hook-form": "^7.71.2",
        "react-signature-canvas": "^1.1.0-alpha.2",
        "recharts": "^3.8.0",
        "tailwind-merge": "^3.5.0",
        "xlsx": "^0.18.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/postcss": "^4",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/archiver": "^7.0.0",
        "@types/node": "^20.19.37",
        "@types/pg": "^8.16.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "babel-plugin-react-compiler": "1.0.0",
        "drizzle-kit": "^0.31.9",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "jsdom": "^29.0.2",
        "shadcn": "^3.8.5",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5",
        "vitest": "^4.1.0"
    }
