{
  "name": "One Laundry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sandcastle": "npx tsx .sandcastle/main.mts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:wipe": "npx tsx db/wipe-db.ts",
    "db:migrate": "npx drizzle-kit push && npx tsx db/apply-custom-schema.ts",
    "db:seed": "npx tsx db/seed/seed.ts",
    "db:seed:workers": "npx tsx db/seed/workers-only.ts",
    "db:reset": "npx tsx db/reset.ts",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:worker": "vitest run app/dashboard/worker services/worker app/api/workers",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^4.3.6",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@sparticuz/chromium": "^147.0.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-table": "^8.21.3",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "xlsx": "^0.18.5",
    "dotenv": "^17.3.1",
    "dotenv-flow": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "tailwind-merge": "^3.5.0",
    "playwright-core": "^1.59.1",
    "postgres": "^3.4.7",
    "recharts": "^3.8.0",
    "react": "19.2.3",
    "react-hook-form": "^7.72.1",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.0",
    "vitest": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.2",
    "typescript": "^5",
    "tw-animate-css": "^1.4.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0"
  }
}
