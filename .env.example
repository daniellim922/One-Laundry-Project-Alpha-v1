# Base env: shared + default mode. Overrides per mode live in `.env.development` / `.env.production`.
# CLI tools use `dotenv-flow` via `lib/load-env-files.ts` (see `.env.example`).
NODE_ENV=development

USERFLOW_LOGIN_EMAIL=
USERFLOW_LOGIN_PASSWORD=

DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
