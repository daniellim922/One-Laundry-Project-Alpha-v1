# Postgres connection string from Supabase → Project Settings → Database
# (direct or pooler URI, depending on how you run Drizzle and the app).
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# API URL and publishable (anon) key from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-supabase-publishable-key

# When self-service signup is disabled in the Supabase Dashboard, create dashboard users under
# Authentication → Users (or via the Auth Admin API with the service role key).

# Playwright userflow login for test/userflow/workers/*.spec.ts.
USERFLOW_LOGIN_EMAIL=replace-with-a-dashboard-user-email
USERFLOW_LOGIN_PASSWORD=replace-with-that-users-password
