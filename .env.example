# Environment files (dotenv-flow style — see https://www.npmjs.com/package/dotenv-flow)
#
# Next.js loads `.env*` on its own; CLI tools (e.g. drizzle-kit) load the same cascade when they
# import `env` from `lib/env.ts` (dotenv-flow runs in Node before Zod validation).
#
# Load order (later wins): `.env.defaults` → `.env` → `.env.local` →
# `.env.${NODE_ENV}` → `.env.${NODE_ENV}.local`
# (`.env.local` is skipped when NODE_ENV=test.)
#
# `lib/env.ts` sets `default_node_env: "development"` for dotenv-flow, so when NODE_ENV is unset
# in the shell, `.env.development` is included. Use hosted Supabase for CLI by running with
# NODE_ENV=production (or set NODE_ENV in `.env`).

# --- `.env` (shared / defaults) ---
# `development` | `production` | `test` — Zod default `development` if missing from process.env.
NODE_ENV=development

# --- `.env.development` (local stack / Supabase CLI) ---
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<anon key from `supabase status`>

# --- `.env.production` (hosted Supabase) ---
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-supabase-publishable-key

# --- `.env.local` (optional machine-specific; between `.env` and `.env.<NODE_ENV>`) ---

# Optional: public site URL for password-reset emails (otherwise inferred from request headers).
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# Supabase → Authentication → URL Configuration → Redirect URLs must include your auth callback, e.g.:
# http://localhost:3000/auth/callback
# http://localhost:3000/auth/update-password

# When self-service signup is disabled in the Supabase Dashboard, create dashboard users under
# Authentication → Users (or via the Auth Admin API with the service role key).

# Validated at runtime via `import { env } from "@/lib/env"`.
