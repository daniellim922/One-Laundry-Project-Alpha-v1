# ChatGPT OAuth: keep credentials under `.sandcastle/.codex/` (mounted to `/home/agent/.codex`).
# Do not set API keys in this file for that mode.
# Optional — API key auth instead of OAuth (omit this line for ChatGPT login):
# OPENAI_API_KEY=
# GitHub personal access token
GH_TOKEN=
# Optional: force Sandcastle to work only on this issue number (unset = pick from list)
SANDCASTLE_ISSUE=
