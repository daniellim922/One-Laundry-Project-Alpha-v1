{
    "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
    "entry": ["src/workers/*.ts", "scripts/*.ts"],
    "ignorePatterns": [
        "**/*.generated.ts",
        "app/globals.css",
        "components/ui/*"
    ],
    "duplicates": {
        "ignore": [
            "**/*.test.ts",
            "**/*.test.tsx",
            "**/*.client.test.ts",
            "**/*.integration.test.ts"
        ]
    },
    "rules": {
        "unused-files": "error",
        "unused-exports": "warn",
        "unused-types": "warn",
        "unused-dependencies": "off",
        "unused-dev-dependencies": "off",
        "unused-optional-dependencies": "off"
    }
}
